---
// Venue / location section with Google Maps embed and directions link.

const mapsEmbedSrc =
  'https://www.google.com/maps?q=Guruvayoor+Temple,+Guruvayur,+Kerala&output=embed';
const directionsUrl =
  'https://www.google.com/maps/search/?api=1&query=Guruvayoor+Temple,+Guruvayur,+Kerala';
---

<section id="location" class="location">
  <div class="section-inner">
    <h2 class="section-heading">Venue</h2>

    <p class="location__description">
      TODO: Add full venue address and any notes for guests (parking, nearby
      landmarks, etc.). Ceremonies will take place in and around Guruvayoor,
      Kerala.
    </p>

    <div class="location__map">
      <iframe
        src={mapsEmbedSrc}
        title="Map showing Guruvayoor Temple"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <a class="location__cta" href={directionsUrl} target="_blank" rel="noopener noreferrer">
      Get Directions
    </a>
  </div>
</section>

<style>
  .location {
    padding: var(--section-padding-y) var(--section-padding-x);
    max-width: var(--page-max-width);
    margin: 0 auto;
  }

  .location__description {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: var(--fs-body-lg);
    max-width: 56ch;
    margin: 0 auto var(--space-6);
  }

  .location__map {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: var(--border-width-hairline) solid var(--color-border);
    box-shadow: var(--shadow-card);
  }

  .location__map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .location__cta {
    display: block;
    width: fit-content;
    margin: var(--space-6) auto 0;
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-maroon);
    color: var(--color-text-on-dark);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    font-size: var(--fs-body-sm);
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast);
  }

  .location__cta:hover {
    background-color: var(--color-maroon-deep);
  }
</style>
