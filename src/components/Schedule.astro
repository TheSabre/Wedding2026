---
// Vertical timeline of the day's events.

const events = [
  {
    time: '7:00 AM',
    title: 'Thaali Kettu',
    // TODO: Confirm temple name and address
    location: 'TODO: Temple name, Guruvayoor',
  },
  {
    time: '10:30 AM',
    title: 'Wedding Ceremony',
    // TODO: Confirm hall name
    location: 'TODO: Hall name',
  },
  {
    time: '12:00 PM',
    title: 'Lunch / Sadya',
    // TODO: Confirm hall name
    location: 'TODO: Hall name',
  },
];
---

<section id="schedule" class="schedule">
  <div class="section-inner">
    <h2 class="section-heading">Schedule</h2>

    <ol class="schedule__timeline">
      {
        events.map((event) => (
          <li class="schedule__item">
            <div class="schedule__marker" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M12 3c4 4 7 7.5 7 11a7 7 0 0 1-14 0c0-3.5 3-7 7-11Z"
                  stroke="var(--color-gold)"
                  stroke-width="1.5"
                  stroke-linejoin="round"
                />
                <path
                  d="M12 9v8M9 13c1 1.5 4 1.5 6 1"
                  stroke="var(--color-gold)"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
            <div class="schedule__content">
              <p class="schedule__time">{event.time}</p>
              <h3 class="schedule__title">{event.title}</h3>
              <p class="schedule__location">{event.location}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .schedule {
    padding: var(--section-padding-y) var(--section-padding-x);
    max-width: var(--page-max-width);
    margin: 0 auto;
    background-color: var(--color-cream-deep);
  }

  .schedule__timeline {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Gold vertical line */
  .schedule__timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 19px;
    width: var(--border-width-accent);
    background-color: var(--color-gold-light);
  }

  .schedule__item {
    position: relative;
    display: flex;
    gap: var(--space-5);
    padding-left: 0;
    padding-bottom: var(--space-7);
  }

  .schedule__item:last-child {
    padding-bottom: 0;
  }

  .schedule__marker {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-cream);
    border: var(--border-width-hairline) solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .schedule__marker svg {
    width: 22px;
    height: 22px;
  }

  .schedule__time {
    font-family: var(--font-display);
    font-size: var(--fs-body-lg);
    color: var(--color-maroon);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .schedule__title {
    font-size: var(--fs-display-md);
    margin-bottom: var(--space-1);
  }

  .schedule__location {
    color: var(--color-text-secondary);
    font-size: var(--fs-body-sm);
  }
</style>
